<mvc:View controllerName="project.controller.pages.characters.InfoCharacter"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page showHeader="false" enableScrolling="true" class="dokkanPage">
        <content>
            <VBox class="pageWrapper">

                <core:Fragment fragmentName="project.view.shared.Header" type="XML"/>

                <VBox class="cardDetailContent">

                    <!-- ══ Top row: left (images + date) / right (text sections) ══ -->
                    <HBox class="cardTopRow" wrap="Wrap">

                        <!-- ── Left column ── -->
                        <VBox class="cardLeftCol">
                            <VBox class="cardThumbBox">
                                <Image src="{thumbnail}" class="cardThumbImg" densityAware="false"/>
                            </VBox>
                            <VBox class="cardArtBox">
                                <Image src="{artwork}" class="cardArtImg" densityAware="false"/>
                            </VBox>
                            <VBox class="cardDateBox">
                                <Text text="{i18n>info.releaseDate}" class="cardDateLabel"/>
                                <Text text="{stats>/releaseDate}"    class="cardDateValue"/>
                            </VBox>
                        </VBox>

                        <!-- ── Right column ── -->
                        <VBox class="cardRightCol">

                            <!-- Name — id para que el controller inyecte la clase de tipo -->
                            <VBox class="cardNameBox" id="cardNameBox">
                                <Text  text="{title}" class="cardSubtitle"/>
                                <Title text="{name}"  class="cardTitle" titleStyle="H1" wrapping="true"/>
                            </VBox>

                            <VBox class="cardSection">
                                <Text text="{i18n>info.leaderSkill}" class="cardSectionTitle"/>
                                <Text text="{leaderSkill}" class="cardSectionText" wrapping="true"/>
                            </VBox>

                            <VBox class="cardSection">
                                <Text text="{i18n>info.superAttack}" class="cardSectionTitle"/>
                                <Text text="{superAttackName}" class="cardSectionSubtitle" wrapping="true"/>
                                <Text text="{superAttack}"     class="cardSectionText"     wrapping="true"/>
                            </VBox>

                            <VBox class="cardSection">
                                <Text text="{i18n>info.ultraSA}" class="cardSectionTitle"/>
                                <Text text="{ultraSAName}" class="cardSectionSubtitle" wrapping="true"/>
                                <Text text="{ultraSA}"     class="cardSectionText"     wrapping="true"/>
                            </VBox>

                            <VBox class="cardSection">
                                <Text text="{i18n>info.passiveSkill}" class="cardSectionTitle"/>
                                <Text text="{passiveName}" class="cardSectionSubtitle" wrapping="true"/>
                                <Text text="{passive}"     class="cardSectionText"     wrapping="true"/>
                            </VBox>

                            <VBox class="cardSection">
                                <Text text="{i18n>info.linkSkills}" class="cardSectionTitle"/>
                                <FlexBox wrap="Wrap" class="linkSkillsGrid" items="{linkSkills>/skills}">
                                    <items>
                                        <Button text="{linkSkills>name}" class="linkSkillBtn"/>
                                    </items>
                                </FlexBox>
                            </VBox>

                            <VBox class="cardSection">
                                <Text text="{i18n>info.categories}" class="cardSectionTitle"/>
                                <FlexBox wrap="Wrap" class="categoriesGrid" items="{categories>/items}">
                                    <items>
                                        <Button text="{categories>name}"
                                                class="categoryChipBtn"
                                                press=".onNavCategory"/>
                                    </items>
                                </FlexBox>
                            </VBox>

                        </VBox>
                    </HBox>

                    <!-- ══ Stats Table — full width, below both columns ══ -->
                    <VBox class="cardSection">
                        <Text text="{i18n>info.stats}" class="cardSectionTitle"/>
                        <VBox class="statsTable">
                            <HBox class="statsRow statsHeaderRow">
                                <Text text="{i18n>info.statLabel}"   class="statCell statLabelCol statsHead"/>
                                <Text text="{i18n>info.statBaseMax}" class="statCell statsHead"/>
                                <Text text="55%"                      class="statCell statsHead"/>
                                <Text text="100%"                     class="statCell statsHead"/>
                            </HBox>
                            <HBox class="statsRow">
                                <Text text="HP"             class="statCell statLabelCol statHP"/>
                                <Text text="{stats>/hp}"    class="statCell"/>
                                <Text text="{stats>/hp55}"  class="statCell"/>
                                <Text text="{stats>/hp100}" class="statCell"/>
                            </HBox>
                            <HBox class="statsRow statsAltRow">
                                <Text text="ATK"             class="statCell statLabelCol statATK"/>
                                <Text text="{stats>/atk}"    class="statCell"/>
                                <Text text="{stats>/atk55}"  class="statCell"/>
                                <Text text="{stats>/atk100}" class="statCell"/>
                            </HBox>
                            <HBox class="statsRow">
                                <Text text="DEF"             class="statCell statLabelCol statDEF"/>
                                <Text text="{stats>/def}"    class="statCell"/>
                                <Text text="{stats>/def55}"  class="statCell"/>
                                <Text text="{stats>/def100}" class="statCell"/>
                            </HBox>
                        </VBox>
                    </VBox>

                </VBox>

                <core:Fragment fragmentName="project.view.shared.Footer" type="XML"/>

            </VBox>
        </content>
    </Page>

</mvc:View>