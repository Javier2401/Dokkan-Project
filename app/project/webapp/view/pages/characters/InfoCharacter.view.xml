<mvc:View controllerName="project.controller.pages.characters.InfoCharacter"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page showHeader="false" enableScrolling="true" class="dokkanPage">
        <content>
            <VBox class="pageWrapper">

                <core:Fragment fragmentName="project.view.shared.Header" type="XML"/>

                <VBox class="cardDetailContent">

                    <HBox class="cardTopRow" wrap="Wrap">

                        <VBox class="cardLeftCol">
                            <VBox class="cardThumbBox">
                                <Image src="{thumbnail}" class="cardThumbImg"/>
                            </VBox>

                            <VBox class="cardArtBox">
                                <Image src="{artwork}" class="cardArtImg"/>
                                <Text text="Release date: {releaseDate}" class="cardReleaseDate"/>
                            </VBox>
                        </VBox>

                        <VBox class="cardRightCol">

                            <VBox class="cardNameBox">
                                <Text text="{rarity}" class="cardSubtitle"/>
                                <Title text="{title} {name}" class="cardTitle" titleStyle="H1"/>
                            </VBox>

                            <VBox class="cardSection">
                                <Text text="Leader Skill" class="cardSectionTitle"/>
                                <Text text="{leaderSkill}" class="cardSectionText"/>
                            </VBox>

                            <VBox class="cardSection">
                                <Text text="Super Attack" class="cardSectionTitle"/>
                                <Text text="{superAttackName}" class="cardSectionSubtitle"/>
                                <Text text="{superAttack}" class="cardSectionText"/>
                                <Text text="SA Lv 20: Super Attack +30%" class="cardSectionSa"/>
                            </VBox>

                            <VBox class="cardSection">
                                <Text text="Ultra Super Attack" class="cardSectionTitle"/>
                                <Text text="{ultraSAName}" class="cardSectionSubtitle"/>
                                <Text text="{ultraSA}" class="cardSectionText"/>
                                <Text text="SA Lv 20: Super Attack +30%" class="cardSectionSa"/>
                            </VBox>

                            <VBox class="cardSection">
                                <Text text="Passive Skill" class="cardSectionTitle"/>
                                <Text text="{passiveName}" class="cardSectionSubtitle"/>
                                <Text text="{passive}" class="cardSectionText"/>
                            </VBox>

                            <VBox class="cardSection">
                                <Text text="Link Skills" class="cardSectionTitle"/>
                                <HBox wrap="Wrap" class="linkSkillsGrid">
                                    <Button text="Super Saiyan"
                                            class="linkSkillBtn"
                                            tooltip="Level 1: Ki +1&#10;Level 10: Ki +2; ATK +10%"/>
                                    <Button text="Kamehameha"
                                            class="linkSkillBtn"
                                            tooltip="Level 1: ATK +500&#10;Level 10: ATK +2500 when HP 50%+"/>
                                    <Button text="Prepared for Battle"
                                            class="linkSkillBtn"
                                            tooltip="Level 1: Ki +1&#10;Level 10: Ki +2"/>
                                    <Button text="Golden Warrior"
                                            class="linkSkillBtn"
                                            tooltip="Level 1: Ki +1&#10;Level 10: Ki +1; ATK, DEF +5%"/>
                                    <Button text="Saiyan Warrior Race"
                                            class="linkSkillBtn"
                                            tooltip="Level 1: ATK +100&#10;Level 10: ATK +700"/>
                                    <Button text="Over in a Flash"
                                            class="linkSkillBtn"
                                            tooltip="Level 1: Ki +1&#10;Level 10: Ki +3"/>
                                    <Button text="Fierce Battle"
                                            class="linkSkillBtn"
                                            tooltip="Level 1: ATK +5%&#10;Level 10: ATK +15%"/>
                                </HBox>
                            </VBox>

                            <VBox class="cardSection">
                                <Text text="Categories" class="cardSectionTitle"/>
                                <HBox wrap="Wrap" class="categoriesGrid">
                                    <Text text="Pure Saiyans"                  class="categoryChip"/>
                                    <Text text="Movie Heroes"                  class="categoryChip"/>
                                    <Text text="Kamehameha"                    class="categoryChip"/>
                                    <Text text="Goku's Family"                 class="categoryChip"/>
                                    <Text text="Legendary Power"               class="categoryChip"/>
                                    <Text text="Representatives of Universe 7" class="categoryChip"/>
                                </HBox>
                            </VBox>

                        </VBox>
                    </HBox>

                </VBox>

                <core:Fragment fragmentName="project.view.shared.Footer" type="XML"/>

            </VBox>
        </content>
    </Page>

</mvc:View>