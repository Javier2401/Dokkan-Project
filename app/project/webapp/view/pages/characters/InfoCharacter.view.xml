<mvc:View controllerName="project.controller.pages.characters.InfoCharacter"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page showHeader="false" enableScrolling="true" class="dokkanPage">
        <content>
            <VBox class="pageWrapper">

                <core:Fragment fragmentName="project.view.shared.Header" type="XML"/>

                <VBox class="cardDetailContent">
                    <HBox class="cardTopRow" wrap="Wrap">

                        <!-- ── Left column: thumbnail + big art + date ── -->
                        <VBox class="cardLeftCol">

                            <VBox class="cardThumbBox">
                                <Image src="{thumbnail}" class="cardThumbImg" densityAware="false"/>
                            </VBox>

                            <VBox class="cardArtBox">
                                <Image src="{artwork}" class="cardArtImg" densityAware="false"/>
                            </VBox>

                            <!-- Release date in its own dedicated box -->
                            <VBox class="cardDateBox">
                                <Text text="{stats>/releaseDate}" class="cardReleaseDateBig"/>
                            </VBox>

                        </VBox>

                        <!-- ── Right column: name, leader, SA, passive, links, categories ── -->
                        <VBox class="cardRightCol">

                            <VBox class="cardNameBox">
                                <Text  text="{title}" class="cardSubtitle"/>
                                <Title text="{name}"  class="cardTitle" titleStyle="H1" wrapping="true"/>
                            </VBox>

                            <VBox class="cardSection">
                                <Text text="Leader Skill" class="cardSectionTitle"/>
                                <Text text="{leaderSkill}" class="cardSectionText" wrapping="true"/>
                            </VBox>

                            <VBox class="cardSection">
                                <Text text="Super Attack" class="cardSectionTitle"/>
                                <Text text="{superAttackName}" class="cardSectionSubtitle" wrapping="true"/>
                                <Text text="{superAttack}"     class="cardSectionText"     wrapping="true"/>
                            </VBox>

                            <VBox class="cardSection">
                                <Text text="Ultra Super Attack" class="cardSectionTitle"/>
                                <Text text="{ultraSAName}" class="cardSectionSubtitle" wrapping="true"/>
                                <Text text="{ultraSA}"     class="cardSectionText"     wrapping="true"/>
                            </VBox>

                            <VBox class="cardSection">
                                <Text text="Passive Skill" class="cardSectionTitle"/>
                                <Text text="{passiveName}" class="cardSectionSubtitle" wrapping="true"/>
                                <Text text="{passive}"     class="cardSectionText"     wrapping="true"/>
                            </VBox>

                            <VBox class="cardSection">
                                <Text text="Link Skills" class="cardSectionTitle"/>
                                <FlexBox wrap="Wrap" class="linkSkillsGrid" items="{linkSkills>/skills}">
                                    <items>
                                        <Button text="{linkSkills>name}" class="linkSkillBtn"/>
                                    </items>
                                </FlexBox>
                            </VBox>

                            <VBox class="cardSection">
                                <Text text="Categories" class="cardSectionTitle"/>
                                <FlexBox wrap="Wrap" class="categoriesGrid" items="{categories>/items}">
                                    <items>
                                        <Button text="{categories>name}"
                                                class="categoryChipBtn"
                                                press=".onNavCategory"/>
                                    </items>
                                </FlexBox>
                            </VBox>

                        </VBox>
                    </HBox>

                    <!-- ── Stats table — full width at the bottom ── -->
                    <VBox class="statsTableBox">
                        <Text text="Stats" class="statsTableTitle"/>
                        <VBox class="statsTable">
                            <!-- Header row -->
                            <HBox class="statsTableRow statsTableHeader">
                                <Text text="Stats"    class="statsTableCell statsTableHead statsColLabel"/>
                                <Text text="Base Max" class="statsTableCell statsTableHead"/>
                                <Text text="55%"      class="statsTableCell statsTableHead"/>
                                <Text text="100%"     class="statsTableCell statsTableHead"/>
                            </HBox>
                            <!-- HP row -->
                            <HBox class="statsTableRow">
                                <Text text="HP"                    class="statsTableCell statsRowLabel statsColorHP"/>
                                <Text text="{stats>/hp}"           class="statsTableCell statsValue"/>
                                <Text text="{stats>/hp55}"         class="statsTableCell statsValue"/>
                                <Text text="{stats>/hp100}"        class="statsTableCell statsValue"/>
                            </HBox>
                            <!-- ATK row -->
                            <HBox class="statsTableRow">
                                <Text text="ATK"                   class="statsTableCell statsRowLabel statsColorATK"/>
                                <Text text="{stats>/atk}"          class="statsTableCell statsValue"/>
                                <Text text="{stats>/atk55}"        class="statsTableCell statsValue"/>
                                <Text text="{stats>/atk100}"       class="statsTableCell statsValue"/>
                            </HBox>
                            <!-- DEF row -->
                            <HBox class="statsTableRow">
                                <Text text="DEF"                   class="statsTableCell statsRowLabel statsColorDEF"/>
                                <Text text="{stats>/def}"          class="statsTableCell statsValue"/>
                                <Text text="{stats>/def55}"        class="statsTableCell statsValue"/>
                                <Text text="{stats>/def100}"       class="statsTableCell statsValue"/>
                            </HBox>
                        </VBox>
                    </VBox>

                </VBox>

                <core:Fragment fragmentName="project.view.shared.Footer" type="XML"/>

            </VBox>
        </content>
    </Page>

</mvc:View>