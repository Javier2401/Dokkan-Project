<mvc:View controllerName="project.controller.pages.characters.InfoCharacter"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page showHeader="false" enableScrolling="true" class="dokkanPage">
        <content>
            <VBox class="pageWrapper">

                <core:Fragment fragmentName="project.view.shared.Header" type="XML"/>

                <VBox class="cardDetailContent">
                    <HBox class="cardTopRow" wrap="Wrap">

                        <VBox class="cardLeftCol">

                            <VBox class="cardThumbBox">
                                <Image src="{thumbnail}" class="cardThumbImg" densityAware="false"/>
                            </VBox>

                            <VBox class="cardArtBox">
                                <Image src="{artwork}" class="cardArtImg" densityAware="false"/>
                                <Text text="{releaseDate}" class="cardReleaseDate"/>
                            </VBox>

                        </VBox>

                        <VBox class="cardRightCol">

                            <VBox class="cardNameBox">
                                <Text text="{title}" class="cardSubtitle"/>
                                <Title text="{name}" class="cardTitle" titleStyle="H1" wrapping="true"/>
                            </VBox>

                            <VBox class="cardSection">
                                <Text text="Stats" class="cardSectionTitle"/>
                                <HBox class="statsRow">
                                    <VBox class="statBox">
                                        <Text text="HP"   class="statLabel"/>
                                        <Text text="{hp}" class="statNumber statHP"/>
                                    </VBox>
                                    <VBox class="statBox">
                                        <Text text="ATK"   class="statLabel"/>
                                        <Text text="{atk}" class="statNumber statATK"/>
                                    </VBox>
                                    <VBox class="statBox">
                                        <Text text="DEF"   class="statLabel"/>
                                        <Text text="{def}" class="statNumber statDEF"/>
                                    </VBox>
                                </HBox>
                            </VBox>

                            <VBox class="cardSection">
                                <Text text="Leader Skill" class="cardSectionTitle"/>
                                <Text text="{leaderSkill}" class="cardSectionText" wrapping="true"/>
                            </VBox>

                            <VBox class="cardSection">
                                <Text text="Super Attack" class="cardSectionTitle"/>
                                <Text text="{superAttackName}" class="cardSectionSubtitle" wrapping="true"/>
                                <Text text="{superAttack}" class="cardSectionText" wrapping="true"/>
                            </VBox>

                            <VBox class="cardSection">
                                <Text text="Ultra Super Attack" class="cardSectionTitle"/>
                                <Text text="{ultraSAName}" class="cardSectionSubtitle" wrapping="true"/>
                                <Text text="{ultraSA}" class="cardSectionText" wrapping="true"/>
                            </VBox>

                            <VBox class="cardSection">
                                <Text text="Passive Skill" class="cardSectionTitle"/>
                                <Text text="{passiveName}" class="cardSectionSubtitle" wrapping="true"/>
                                <Text text="{passive}" class="cardSectionText" wrapping="true"/>
                            </VBox>

                            <VBox class="cardSection">
                                <Text text="Link Skills" class="cardSectionTitle"/>
                                <FlexBox wrap="Wrap" class="linkSkillsGrid" items="{linkSkills>/skills}">
                                    <Button text="{linkSkills>name}" class="linkSkillBtn" tooltip="LEVEL 1:&#xa;LEVEL 10:"/>
                                </FlexBox>
                            </VBox>

                            <VBox class="cardSection">
                                <Text text="Categories" class="cardSectionTitle"/>
                                <Text text="{categories}" class="cardSectionText" wrapping="true"/>
                            </VBox>

                        </VBox>
                    </HBox>
                </VBox>

                <core:Fragment fragmentName="project.view.shared.Footer" type="XML"/>

            </VBox>
        </content>
    </Page>

</mvc:View>