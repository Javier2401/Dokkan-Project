<mvc:View controllerName="project.controller.pages.characters.CategoryCharacter"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page showHeader="false" enableScrolling="true" class="dokkanPage">
        <content>
            <VBox class="pageWrapper">

                <core:Fragment fragmentName="project.view.shared.Header" type="XML"/>

                <VBox class="pageContent">

                    <!-- ── 1. Category name hero ── -->
                    <VBox class="categoryHero">
                        <Title text="{chars>/categoryName}"
                               titleStyle="H1"
                               class="categoryHeroTitle"
                               wrapping="true"/>
                    </VBox>

                    <!-- ── 2. Leaders panel ── -->
                    <Panel class="dokkanPanel" headerText="Leaders">
                        <content>

                            <VBox alignItems="Center" class="categoryEmptyState"
                                  visible="{chars>/hasNoLeaders}">
                                <Text text="No leaders found for this category."
                                      class="categoryEmptyText"/>
                            </VBox>

                            <FlexBox wrap="Wrap" justifyContent="Center"
                                     class="characterRow"
                                     items="{chars>/leaders}">
                                <items>
                                    <VBox class="characterCard">
                                        <Image src="{chars>thumbnail}"
                                               class="characterImg"
                                               press=".onNavInfoCharacter"
                                               densityAware="false"/>
                                        <HBox justifyContent="Center" wrap="Wrap">
                                            <Text text="{chars>name}" class="characterCardName"/>
                                        </HBox>
                                    </VBox>
                                </items>
                            </FlexBox>

                        </content>
                    </Panel>

                    <!-- ── 3. Members panel ── -->
                    <Panel class="dokkanPanel" headerText="Members">
                        <content>

                            <VBox alignItems="Center" class="categoryEmptyState"
                                  visible="{chars>/hasNoMembers}">
                                <Text text="No members found for this category."
                                      class="categoryEmptyText"/>
                            </VBox>

                            <FlexBox wrap="Wrap" justifyContent="Center"
                                     class="characterRow"
                                     items="{chars>/members}">
                                <items>
                                    <VBox class="characterCard">
                                        <Image src="{chars>thumbnail}"
                                               class="characterImg"
                                               press=".onNavInfoCharacter"
                                               densityAware="false"/>
                                        <HBox justifyContent="Center" wrap="Wrap">
                                            <Text text="{chars>name}" class="characterCardName"/>
                                        </HBox>
                                    </VBox>
                                </items>
                            </FlexBox>

                        </content>
                    </Panel>

                </VBox>

                <core:Fragment fragmentName="project.view.shared.Footer" type="XML"/>

            </VBox>
        </content>
    </Page>

</mvc:View>