<mvc:View controllerName="project.controller.pages.characters.CategoryCharacter"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page showHeader="false" enableScrolling="true" class="dokkanPage">
        <content>
            <VBox class="pageWrapper">

                <core:Fragment fragmentName="project.view.shared.Header" type="XML"/>

                <VBox class="pageContent">

                    <!-- ── Category hero title ── -->
                    <VBox class="categoryHero">
                        <Title text="{chars>/categoryName}"
                               titleStyle="H1"
                               class="categoryHeroTitle"
                               wrapping="true"/>
                    </VBox>

                    <!-- ══ Leaders ══ -->
                    <Panel class="dokkanPanel" headerText="Leaders">
                        <content>
                            <VBox visible="{chars>/hasNoLeaders}" class="categoryEmptyState">
                                <Text text="No leaders found for this category." class="categoryEmptyText"/>
                            </VBox>
                            <FlexBox wrap="Wrap" justifyContent="Center" class="characterRow"
                                     visible="{chars>/hasLeaders}"
                                     items="{chars>/leaders}">
                                <items>
                                    <VBox class="characterCard leaderCard">
                                        <Image src="{chars>thumbnail}"
                                               class="characterImg"
                                               press=".onNavInfoCharacter"
                                               densityAware="false"/>
                                        <!-- 1×4 horizontal stats row -->
                                        <HBox class="leaderStatGrid">
                                            <VBox class="leaderStatBox leaderStatKi">
                                                <Text text="KI"                     class="leaderStatLabel"/>
                                                <Text text="{chars>leaderStats/ki}" class="leaderStatVal"/>
                                            </VBox>
                                            <VBox class="leaderStatBox leaderStatHP">
                                                <Text text="HP"                     class="leaderStatLabel"/>
                                                <Text text="{chars>leaderStats/hp}" class="leaderStatVal"/>
                                            </VBox>
                                            <VBox class="leaderStatBox leaderStatATK">
                                                <Text text="ATK"                     class="leaderStatLabel"/>
                                                <Text text="{chars>leaderStats/atk}" class="leaderStatVal"/>
                                            </VBox>
                                            <VBox class="leaderStatBox leaderStatDEF">
                                                <Text text="DEF"                     class="leaderStatLabel"/>
                                                <Text text="{chars>leaderStats/def}" class="leaderStatVal"/>
                                            </VBox>
                                        </HBox>
                                    </VBox>
                                </items>
                            </FlexBox>
                        </content>
                    </Panel>

                    <!-- ══ Sub-Leaders / Rainbow ══ -->
                    <Panel class="dokkanPanel" headerText="Sub-Leaders / Rainbow">
                        <content>
                            <VBox visible="{chars>/hasNoSubLeaders}" class="categoryEmptyState">
                                <Text text="No sub-leaders found for this category." class="categoryEmptyText"/>
                            </VBox>
                            <FlexBox wrap="Wrap" justifyContent="Center" class="characterRow"
                                     visible="{chars>/hasSubLeaders}"
                                     items="{chars>/subLeaders}">
                                <items>
                                    <VBox class="characterCard leaderCard">
                                        <Image src="{chars>thumbnail}"
                                               class="characterImg"
                                               press=".onNavInfoCharacter"
                                               densityAware="false"/>
                                        <!-- 1×4 horizontal stats row -->
                                        <HBox class="leaderStatGrid">
                                            <VBox class="leaderStatBox leaderStatKi">
                                                <Text text="KI"                     class="leaderStatLabel"/>
                                                <Text text="{chars>leaderStats/ki}" class="leaderStatVal"/>
                                            </VBox>
                                            <VBox class="leaderStatBox leaderStatHP">
                                                <Text text="HP"                     class="leaderStatLabel"/>
                                                <Text text="{chars>leaderStats/hp}" class="leaderStatVal"/>
                                            </VBox>
                                            <VBox class="leaderStatBox leaderStatATK">
                                                <Text text="ATK"                     class="leaderStatLabel"/>
                                                <Text text="{chars>leaderStats/atk}" class="leaderStatVal"/>
                                            </VBox>
                                            <VBox class="leaderStatBox leaderStatDEF">
                                                <Text text="DEF"                     class="leaderStatLabel"/>
                                                <Text text="{chars>leaderStats/def}" class="leaderStatVal"/>
                                            </VBox>
                                        </HBox>
                                    </VBox>
                                </items>
                            </FlexBox>
                        </content>
                    </Panel>

                    <!-- ══ Cards (image only) ══ -->
                    <Panel class="dokkanPanel" headerText="Cards">
                        <content>
                            <VBox visible="{chars>/hasNoCards}" class="categoryEmptyState">
                                <Text text="No cards found for this category." class="categoryEmptyText"/>
                            </VBox>
                            <FlexBox wrap="Wrap" justifyContent="Center" class="characterRow"
                                     items="{chars>/cards}">
                                <items>
                                    <VBox class="characterCard">
                                        <Image src="{chars>thumbnail}"
                                               class="characterImg"
                                               press=".onNavInfoCharacter"
                                               densityAware="false"/>
                                    </VBox>
                                </items>
                            </FlexBox>
                        </content>
                    </Panel>

                </VBox>

                <core:Fragment fragmentName="project.view.shared.Footer" type="XML"/>

            </VBox>
        </content>
    </Page>

</mvc:View>