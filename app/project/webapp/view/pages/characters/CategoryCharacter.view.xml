<mvc:View controllerName="project.controller.pages.characters.CategoryCharacter"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page showHeader="false" enableScrolling="true" class="dokkanPage">
        <content>
            <VBox class="pageWrapper">

                <core:Fragment fragmentName="project.view.shared.Header" type="XML"/>

                <VBox class="pageContent">

                    <VBox class="categoryHero">
                        <Title text="{chars>/categoryName}"
                               titleStyle="H1"
                               class="categoryHeroTitle"
                               wrapping="true"/>
                    </VBox>

                    <!-- ── Leaders ── -->
                    <Panel class="dokkanPanel" headerText="Leaders">
                        <content>
                            <VBox visible="{chars>/hasNoLeaders}" class="categoryEmptyState">
                                <Text text="No leaders found for this category." class="categoryEmptyText"/>
                            </VBox>
                            <VBox visible="{chars>/hasLeaders}">
                                <HBox class="catLeaderTableHeader">
                                    <Text text="Character"    class="catLeaderCharCol catLeaderHeaderText"/>
                                    <Text text="Leader Skill" class="catLeaderSkillCol catLeaderHeaderText"/>
                                </HBox>
                                <List items="{chars>/leaders}" showSeparators="Inner" class="catLeaderList">
                                    <items>
                                        <CustomListItem type="Inactive" class="catLeaderListItem">
                                            <HBox class="catLeaderRow" alignItems="Center">
                                                <VBox class="catLeaderCharCol" alignItems="Center">
                                                    <Image src="{chars>thumbnail}"
                                                           class="catLeaderThumbImg"
                                                           press=".onNavInfoCharacter"
                                                           densityAware="false"/>
                                                    <Text text="{chars>name}" class="catLeaderName" wrapping="true"/>
                                                </VBox>
                                                <Text text="{chars>leaderSkill}"
                                                      class="catLeaderSkillCol catLeaderSkillText"
                                                      wrapping="true"/>
                                            </HBox>
                                        </CustomListItem>
                                    </items>
                                </List>
                            </VBox>
                        </content>
                    </Panel>

                    <!-- ── Sub-Leaders / Rainbow ── -->
                    <Panel class="dokkanPanel" headerText="Sub-Leaders / Rainbow">
                        <content>
                            <VBox visible="{chars>/hasNoSubLeaders}" class="categoryEmptyState">
                                <Text text="No sub-leaders found for this category." class="categoryEmptyText"/>
                            </VBox>
                            <VBox visible="{chars>/hasSubLeaders}">
                                <HBox class="catLeaderTableHeader">
                                    <Text text="Character"    class="catLeaderCharCol catLeaderHeaderText"/>
                                    <Text text="Leader Skill" class="catLeaderSkillCol catLeaderHeaderText"/>
                                </HBox>
                                <List items="{chars>/subLeaders}" showSeparators="Inner" class="catLeaderList">
                                    <items>
                                        <CustomListItem type="Inactive" class="catLeaderListItem">
                                            <HBox class="catLeaderRow" alignItems="Center">
                                                <VBox class="catLeaderCharCol" alignItems="Center">
                                                    <Image src="{chars>thumbnail}"
                                                           class="catLeaderThumbImg"
                                                           press=".onNavInfoCharacter"
                                                           densityAware="false"/>
                                                    <Text text="{chars>name}" class="catLeaderName" wrapping="true"/>
                                                </VBox>
                                                <Text text="{chars>leaderSkill}"
                                                      class="catLeaderSkillCol catLeaderSkillText"
                                                      wrapping="true"/>
                                            </HBox>
                                        </CustomListItem>
                                    </items>
                                </List>
                            </VBox>
                        </content>
                    </Panel>

                    <!-- ── Cards ── -->
                    <Panel class="dokkanPanel" headerText="Cards">
                        <content>
                            <VBox visible="{chars>/hasNoCards}" class="categoryEmptyState">
                                <Text text="No cards found for this category." class="categoryEmptyText"/>
                            </VBox>
                            <FlexBox wrap="Wrap" justifyContent="Center" class="characterRow"
                                     items="{chars>/cards}">
                                <items>
                                    <VBox class="characterCard catCard">
                                        <Image src="{chars>thumbnail}"
                                               class="characterImg"
                                               press=".onNavInfoCharacter"
                                               densityAware="false"/>
                                        <!-- HP / ATK / DEF stat tiles -->
                                        <HBox class="catStatGrid">
                                            <VBox class="catStatBox catStatHP">
                                                <Text text="HP"          class="catStatLabel"/>
                                                <Text text="{chars>hp}"  class="catStatVal"/>
                                            </VBox>
                                            <VBox class="catStatBox catStatATK">
                                                <Text text="ATK"         class="catStatLabel"/>
                                                <Text text="{chars>atk}" class="catStatVal"/>
                                            </VBox>
                                            <VBox class="catStatBox catStatDEF">
                                                <Text text="DEF"         class="catStatLabel"/>
                                                <Text text="{chars>def}" class="catStatVal"/>
                                            </VBox>
                                        </HBox>
                                    </VBox>
                                </items>
                            </FlexBox>
                        </content>
                    </Panel>

                </VBox>

                <core:Fragment fragmentName="project.view.shared.Footer" type="XML"/>

            </VBox>
        </content>
    </Page>

</mvc:View>