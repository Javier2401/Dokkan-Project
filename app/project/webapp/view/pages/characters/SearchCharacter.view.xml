<mvc:View controllerName="project.controller.pages.characters.SearchCharacter"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page showHeader="false" enableScrolling="true" class="dokkanPage">
        <content>
            <VBox class="pageWrapper">

                <core:Fragment fragmentName="project.view.shared.Header" type="XML"/>

                <VBox class="pageContent">

                    <!-- ── Search bar ── -->
                    <VBox class="searchBarWrapper">
                        <SearchField
                            placeholder="Search by name or title…"
                            search=".onSearch"
                            liveChange=".onLiveSearch"
                            class="characterSearchField"
                            showSearchButton="true"/>
                    </VBox>

                    <!-- ── Results panel ── -->
                    <Panel class="dokkanPanel" headerText="Search Results">
                        <content>

                            <!-- Estado vacío / inicial -->
                            <VBox class="searchEmptyState" visible="{chars>/showEmpty}">
                                <Image src="images/logo.png" class="searchEmptyIcon" densityAware="false"/>
                                <Text text="{chars>/emptyMessage}" class="searchEmptyText"/>
                            </VBox>

                            <!-- Grid de resultados -->
                            <FlexBox wrap="Wrap" justifyContent="Center" class="characterRow"
                                     visible="{chars>/hasResults}"
                                     items="{chars>/results}">
                                <items>
                                    <VBox class="characterCard searchResultCard" alignItems="Center">
                                        <Image src="{chars>thumbnail}"
                                               class="characterImg"
                                               press=".onNavInfoCharacter"
                                               densityAware="false"/>
                                        <Text text="{chars>name}"
                                              class="searchResultName"
                                              wrapping="true"/>
                                    </VBox>
                                </items>
                            </FlexBox>

                        </content>
                    </Panel>

                </VBox>

                <core:Fragment fragmentName="project.view.shared.Footer" type="XML"/>

            </VBox>
        </content>
    </Page>

</mvc:View>