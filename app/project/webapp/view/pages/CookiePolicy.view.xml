<mvc:View controllerName="project.controller.pages.CookiePolicy"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page showHeader="false" enableScrolling="true" class="dokkanPage">
        <content>
            <VBox class="pageWrapper">
                <core:Fragment fragmentName="project.view.shared.Header" type="XML"/>
                <VBox class="legalPageContent">
                    <VBox class="legalCard">
                        <VBox class="legalHero">
                            <Title text="{i18n>cookie.hero.title}" titleStyle="H1" class="legalHeroTitle"/>
                            <Text text="{i18n>cookie.hero.date}" class="legalHeroDate"/>
                        </VBox>
                        <VBox class="legalSection">
                            <Title text="{i18n>cookie.s1.title}" titleStyle="H3" class="legalSectionTitle"/>
                            <Text wrapping="true" text="{i18n>cookie.s1.text}" class="legalSectionText"/>
                        </VBox>
                        <VBox class="legalSection">
                            <Title text="{i18n>cookie.s2.title}" titleStyle="H3" class="legalSectionTitle"/>
                            <Text wrapping="true" text="{i18n>cookie.s2.text}" class="legalSectionText"/>
                        </VBox>
                        <VBox class="legalSection">
                            <Title text="{i18n>cookie.s3.title}" titleStyle="H3" class="legalSectionTitle"/>
                            <VBox class="legalTable">
                                <HBox class="legalTableHeader">
                                    <Text text="{i18n>cookie.s3.col.name}"     class="legalTableCell legalTableHead"/>
                                    <Text text="{i18n>cookie.s3.col.purpose}"  class="legalTableCell legalTableHead"/>
                                    <Text text="{i18n>cookie.s3.col.duration}" class="legalTableCell legalTableHead"/>
                                </HBox>
                                <HBox class="legalTableRow">
                                    <Text text="{i18n>cookie.s3.row1.name}"     class="legalTableCell legalTableMono"/>
                                    <Text text="{i18n>cookie.s3.row1.purpose}"  class="legalTableCell"/>
                                    <Text text="{i18n>cookie.s3.row1.duration}" class="legalTableCell"/>
                                </HBox>
                                <HBox class="legalTableRow">
                                    <Text text="{i18n>cookie.s3.row2.name}"     class="legalTableCell legalTableMono"/>
                                    <Text text="{i18n>cookie.s3.row2.purpose}"  class="legalTableCell"/>
                                    <Text text="{i18n>cookie.s3.row2.duration}" class="legalTableCell"/>
                                </HBox>
                            </VBox>
                        </VBox>
                        <VBox class="legalSection">
                            <Title text="{i18n>cookie.s4.title}" titleStyle="H3" class="legalSectionTitle"/>
                            <Text wrapping="true" text="{i18n>cookie.s4.text}" class="legalSectionText"/>
                        </VBox>
                        <VBox class="legalSection">
                            <Title text="{i18n>cookie.s5.title}" titleStyle="H3" class="legalSectionTitle"/>
                            <Text wrapping="true" text="{i18n>cookie.s5.text}" class="legalSectionText"/>
                        </VBox>
                        <VBox class="legalSection">
                            <Title text="{i18n>cookie.s6.title}" titleStyle="H3" class="legalSectionTitle"/>
                            <Text wrapping="true" text="{i18n>cookie.s6.text}" class="legalSectionText"/>
                        </VBox>
                    </VBox>
                </VBox>
                <core:Fragment fragmentName="project.view.shared.Footer" type="XML"/>
            </VBox>
        </content>
    </Page>

</mvc:View>