<mvc:View controllerName="project.controller.pages.TermsOfUse"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page showHeader="false" enableScrolling="true" class="dokkanPage">
        <content>
            <VBox class="pageWrapper">
                <core:Fragment fragmentName="project.view.shared.Header" type="XML"/>
                <VBox class="legalPageContent">
                    <VBox class="legalCard">
                        <VBox class="legalHero">
                            <Title text="{i18n>terms.hero.title}" titleStyle="H1" class="legalHeroTitle"/>
                            <Text text="{i18n>terms.hero.date}" class="legalHeroDate"/>
                        </VBox>
                        <VBox class="legalSection">
                            <Title text="{i18n>terms.s1.title}" titleStyle="H3" class="legalSectionTitle"/>
                            <Text wrapping="true" text="{i18n>terms.s1.text}" class="legalSectionText"/>
                        </VBox>
                        <VBox class="legalSection">
                            <Title text="{i18n>terms.s2.title}" titleStyle="H3" class="legalSectionTitle"/>
                            <Text wrapping="true" text="{i18n>terms.s2.text}" class="legalSectionText"/>
                        </VBox>
                        <VBox class="legalSection">
                            <Title text="{i18n>terms.s3.title}" titleStyle="H3" class="legalSectionTitle"/>
                            <Text wrapping="true" text="{i18n>terms.s3.text}" class="legalSectionText"/>
                        </VBox>
                        <VBox class="legalSection">
                            <Title text="{i18n>terms.s4.title}" titleStyle="H3" class="legalSectionTitle"/>
                            <Text wrapping="true" text="{i18n>terms.s4.text}" class="legalSectionText"/>
                        </VBox>
                        <VBox class="legalSection">
                            <Title text="{i18n>terms.s5.title}" titleStyle="H3" class="legalSectionTitle"/>
                            <Text wrapping="true" text="{i18n>terms.s5.text}" class="legalSectionText"/>
                        </VBox>
                        <VBox class="legalSection">
                            <Title text="{i18n>terms.s6.title}" titleStyle="H3" class="legalSectionTitle"/>
                            <Text wrapping="true" text="{i18n>terms.s6.text}" class="legalSectionText"/>
                        </VBox>
                        <VBox class="legalSection">
                            <Title text="{i18n>terms.s7.title}" titleStyle="H3" class="legalSectionTitle"/>
                            <Text wrapping="true" text="{i18n>terms.s7.text}" class="legalSectionText"/>
                        </VBox>
                        <VBox class="legalSection">
                            <Title text="{i18n>terms.s8.title}" titleStyle="H3" class="legalSectionTitle"/>
                            <Text wrapping="true" text="{i18n>terms.s8.text}" class="legalSectionText"/>
                        </VBox>
                        <VBox class="legalSection">
                            <Title text="{i18n>terms.s9.title}" titleStyle="H3" class="legalSectionTitle"/>
                            <Text wrapping="true" text="{i18n>terms.s9.text}" class="legalSectionText"/>
                        </VBox>
                    </VBox>
                </VBox>
                <core:Fragment fragmentName="project.view.shared.Footer" type="XML"/>
            </VBox>
        </content>
    </Page>

</mvc:View>