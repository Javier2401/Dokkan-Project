<mvc:View controllerName="project.controller.main.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page showHeader="false" enableScrolling="false" class="dokkanPage">
        <content>
            <VBox class="pageWrapper" width="100%">

                <core:Fragment fragmentName="project.view.shared.Header" type="XML"/>

                <VBox class="pageContent">

                    <Panel class="dokkanPanel" headerText="{i18n>panel.upcoming}">
                        <content>
                            <FlexBox wrap="Wrap" justifyContent="Center" class="characterRow"
                                    items="{path: '/Characters', filters: [{path: 'isUpcoming', operator: 'EQ', value1: true}]}">
                                <items>
                                    <VBox class="characterCard">
                                        <Image src="{thumbnail}" class="characterImg" press=".onNavInfoCharacter"/>
                                        <Text text="{rarity}" class="characterDate"/>
                                    </VBox>
                                </items>
                            </FlexBox>
                        </content>
                    </Panel>

                    <Panel class="dokkanPanel" headerText="{i18n>panel.recent}">
                        <content>
                            <FlexBox wrap="Wrap" justifyContent="Center" class="characterRow"
                                    items="{path: '/Characters', filters: [{path: 'isUpcoming', operator: 'EQ', value1: false}]}">
                                <items>
                                    <VBox class="characterCard">
                                        <Image src="{thumbnail}" class="characterImg" press=".onNavInfoCharacter"/>
                                        <Text text="{rarity}" class="characterDate"/>
                                    </VBox>
                                </items>
                            </FlexBox>
                        </content>
                    </Panel>

                </VBox>

                <core:Fragment fragmentName="project.view.shared.Footer" type="XML"/>

            </VBox>
        </content>
    </Page>

</mvc:View>