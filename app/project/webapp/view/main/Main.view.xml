<mvc:View controllerName="project.controller.main.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page showHeader="false" enableScrolling="true" class="dokkanPage">
        <content>
            <VBox class="pageWrapper" width="100%">

                <core:Fragment fragmentName="project.view.shared.Header" type="XML"/>

                <VBox class="pageContent">

                    <!-- ── Upcoming Characters ── -->
                    <Panel class="dokkanPanel" headerText="{i18n>panel.upcoming}">
                        <content>
                            <FlexBox wrap="Wrap" justifyContent="Center" class="characterRow"
                                     items="{chars>/upcoming}">
                                <items>
                                    <VBox class="characterCard">
                                        <Image src="{chars>thumbnail}"
                                               class="characterImg"
                                               press=".onNavInfoCharacter"
                                               densityAware="false"/>
                                        <Text text="{chars>releaseDateFmt}" class="characterDate characterDateUpcoming"/>
                                    </VBox>
                                </items>
                            </FlexBox>
                        </content>
                    </Panel>

                    <!-- ── Recent Characters (sin fecha) ── -->
                    <Panel class="dokkanPanel" headerText="{i18n>panel.recent}">
                        <content>
                            <FlexBox wrap="Wrap" justifyContent="Center" class="characterRow"
                                     items="{chars>/recent}">
                                <items>
                                    <VBox class="characterCard">
                                        <Image src="{chars>thumbnail}"
                                               class="characterImg"
                                               press=".onNavInfoCharacter"
                                               densityAware="false"/>
                                    </VBox>
                                </items>
                            </FlexBox>
                        </content>
                    </Panel>

                </VBox>

                <core:Fragment fragmentName="project.view.shared.Footer" type="XML"/>

            </VBox>
        </content>
    </Page>

</mvc:View>