<mvc:View controllerName="project.controller.InfoCharacter"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page showHeader="false" enableScrolling="true" class="dokkanPage">
        <content>
            <VBox class="pageWrapper">

                <core:Fragment fragmentName="project.view.fragments.Header" type="XML"/>

                <VBox class="cardDetailContent">

                    <HBox class="cardTopRow" wrap="Wrap">

                        <!-- ═══ COLUMNA IZQUIERDA ═══ -->
                        <VBox class="cardLeftCol">

                            <VBox class="cardThumbBox">
                                <Image src="https://via.placeholder.com/150x150/4a90d9/ffffff?text=CARD"
                                       class="cardThumbImg"/>
                            </VBox>

                            <VBox class="cardArtBox">
                                <Image src="https://via.placeholder.com/280x400/ccddee/333333?text=ARTWORK"
                                       class="cardArtImg"/>
                                <Text text="Release date: 26/09/2024" class="cardReleaseDate"/>
                            </VBox>

                        </VBox>

                        <!-- ═══ COLUMNA DERECHA ═══ -->
                        <VBox class="cardRightCol">

                            <!-- 1. NOMBRE -->
                            <VBox class="cardNameBox">
                                <Text text="SUPER SAIYAN" class="cardSubtitle"/>
                                <Title text="Son Goku" class="cardTitle" titleStyle="H1"/>
                            </VBox>

                            <!-- 2. LEADER SKILL -->
                            <VBox class="cardSection">
                                <Text text="Leader Skill" class="cardSectionTitle"/>
                                <Text text="'Pure Saiyans' or 'Movie Heroes' Category Ki +4 and HP, ATK &amp; DEF +170%; plus an additional ATK &amp; DEF +10% per Rainbow Ki Sphere obtained."
                                      class="cardSectionText"/>
                            </VBox>

                            <!-- 3. ULTRA SUPER ATTACK -->
                            <VBox class="cardSection">
                                <Text text="Ultra Super Attack" class="cardSectionTitle"/>
                                <Text text="Kamehameha" class="cardSectionSubtitle"/>
                                <Text text="Raises ATK &amp; DEF for 1 turn and causes mega-colossal damage to enemy."
                                      class="cardSectionText"/>
                                <Text text="SA Lv 20: Super Attack +30%" class="cardSectionSa"/>
                            </VBox>

                            <!-- 4. SUPER ATTACK -->
                            <VBox class="cardSection">
                                <Text text="Super Attack" class="cardSectionTitle"/>
                                <Text text="Shocking Waves" class="cardSectionSubtitle"/>
                                <Text text="Raises ATK &amp; DEF for 1 turn and causes colossal damage to enemy."
                                      class="cardSectionText"/>
                                <Text text="SA Lv 20: Super Attack +30%" class="cardSectionSa"/>
                            </VBox>

                            <!-- 5. PASSIVE SKILL -->
                            <VBox class="cardSection">
                                <Text text="Passive Skill" class="cardSectionTitle"/>
                                <Text text="Mastered Power" class="cardSectionSubtitle"/>
                                <Text text="ATK &amp; DEF +120%; plus an additional ATK +10% (up to 50%) for each attack performed."
                                      class="cardSectionText"/>
                            </VBox>

                            <!-- 6. LINK SKILLS — tooltip muestra Level 1 al hover -->
                            <VBox class="cardSection">
                                <Text text="Link Skills" class="cardSectionTitle"/>
                                <HBox wrap="Wrap" class="linkSkillsGrid">
                                    <Button text="Super Saiyan"
                                            class="linkSkillBtn"
                                            tooltip="Level 1: Ki +1&#10;Level 10: Ki +2; ATK +10%"/>
                                    <Button text="Kamehameha"
                                            class="linkSkillBtn"
                                            tooltip="Level 1: ATK +500&#10;Level 10: ATK +2500 when HP 50%+"/>
                                    <Button text="Prepared for Battle"
                                            class="linkSkillBtn"
                                            tooltip="Level 1: Ki +1&#10;Level 10: Ki +2"/>
                                    <Button text="Golden Warrior"
                                            class="linkSkillBtn"
                                            tooltip="Level 1: Ki +1&#10;Level 10: Ki +1; ATK, DEF +5%"/>
                                    <Button text="Saiyan Warrior Race"
                                            class="linkSkillBtn"
                                            tooltip="Level 1: ATK +100&#10;Level 10: ATK +700"/>
                                    <Button text="Over in a Flash"
                                            class="linkSkillBtn"
                                            tooltip="Level 1: Ki +1&#10;Level 10: Ki +3"/>
                                    <Button text="Fierce Battle"
                                            class="linkSkillBtn"
                                            tooltip="Level 1: ATK +5%&#10;Level 10: ATK +15%"/>
                                </HBox>
                            </VBox>

                            <!-- 7. CATEGORIES -->
                            <VBox class="cardSection">
                                <Text text="Categories" class="cardSectionTitle"/>
                                <HBox wrap="Wrap" class="categoriesGrid">
                                    <Text text="Pure Saiyans"                  class="categoryChip"/>
                                    <Text text="Movie Heroes"                  class="categoryChip"/>
                                    <Text text="Kamehameha"                    class="categoryChip"/>
                                    <Text text="Goku's Family"                 class="categoryChip"/>
                                    <Text text="Legendary Power"               class="categoryChip"/>
                                    <Text text="Representatives of Universe 7" class="categoryChip"/>
                                </HBox>
                            </VBox>

                        </VBox>
                    </HBox>

                </VBox>

                <core:Fragment fragmentName="project.view.fragments.Footer" type="XML"/>

            </VBox>
        </content>
    </Page>

</mvc:View>